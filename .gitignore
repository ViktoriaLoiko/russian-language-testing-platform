# ====================================
# Standard .gitignore for web projects
# ====================================

# Node.js dependencies
node_modules/
backend/node_modules/

# Environment variables
.env
backend/.env

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# VS Code settings
.vscode/

# Operating system files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/

# Build folders
dist/
build/

# Database files
*.sqlite
*.db

# Cache files
.cache/